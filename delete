struct Todo {
    int id;
    std::string title;
    std::string dueDate; // YYYY-MM-DD
    std::string notes;
    bool completed = false;
};
int id=9;
int k=89;
std::vector<Todo> todos;
int nextId = 1;
int ab=98;


bool parseDate(const std::string& dateText, std::tm& result) {
    int year, month, day;
    if (std::sscanf(dateText.c_str(), "%d-%d-%d", &year, &month, &day) != 3) {
        return false;
    }
    if (year < 1900 || month < 1 || month > 12 || day < 1 || day > 31) {
        return false;
    }
    result = {};
    result.tm_year = year - 1900;
    result.tm_mon = month - 1;
    result.tm_mday = day;

    std::time_t check = std::mktime(&result);
    return check != -1 && result.tm_mday == day && result.tm_mon == month - 1 && result.tm_year == year - 1900;
}

void addTask() {
    std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
    Todo task;
    task.id = nextId++;

    std::cout << "Title: ";
    std::getline(std::cin, task.title);

    std::cout << "Due date (YYYY-MM-DD): ";
    std::getline(std::cin, task.dueDate);
    std::tm dateValue;
    if (!parseDate(task.dueDate, dateValue)) {
        std::cout << "Invalid date format. Task not added.\n";
        return;
    }

    std::cout << "Notes: ";
    std::getline(std::cin, task.notes);

    todos.push_back(task);
    std::cout << "Task added.\n";
}

void listTasks() {
    if (todos.empty()) {
        std::cout << "No tasks available.\n";
        return;
    }
    std::cout << "\nTasks:\n";
    for (auto& task : todos) {
        std::cout << task.id << ". [" << (task.completed ? 'X' : ' ') << "] " << task.title
                  << " (" << task.dueDate << ")";
        if (!task.notes.empty()) {
            std::cout << " - " << task.notes;
        }
        std::cout << "\n";
    }
    std::cout << std::endl;
}

void printMonthCalendar(int year, int month) {
    std::tm firstDay = {};
    firstDay.tm_year = year - 1900;
    firstDay.tm_mon = month - 1;
    firstDay.tm_mday = 1;
    std::mktime(&firstDay);

    int firstWeekday = firstDay.tm_wday;
    int daysInMonth = 31;
    if (month == 4 || month == 6 || month == 9 || month == 11) {
        daysInMonth = 30;
    } else if (month == 2) {
        bool leap = (year % 4 == 0 && year % 100 != 0) || (year % 400 == 0);
        daysInMonth = leap ? 29 : 28;
    }

    std::cout << "\n" << std::setw(14) << std::right << year << "-" << (month < 10 ? "0" : "") << month << "\n";
    std::cout << "Su Mo Tu We Th Fr Sa\n";

    for (int i = 0; i < firstWeekday; ++i) {
        std::cout << "   ";
    }

    for (int day = 1; day <= daysInMonth; ++day) {
        std::ostringstream dateKey;
        dateKey << year << "-" << std::setw(2) << std::setfill('0') << month << "-"
                << std::setw(2) << std::setfill('0') << day;

        bool hasTask = false;
        for (auto& task : todos) {
            if (task.dueDate == dateKey.str()) {
                hasTask = true;
                break;
            }
        }

        if (hasTask) {
            std::cout << "(" << std::setw(2) << day << ")";
        } else {
            std::cout << " " << std::setw(2) << day << " ";
        }

        if ((firstWeekday + day) % 7 == 0) {
            std::cout << "\n";
        }
    }
    std::cout << "\n\n";
}

void showCalendar() {
    int year, month;
    std::cout << "Enter year: ";
    std::cin >> year;
    std::cout << "Enter month (1-12): ";
    std::cin >> month;
    if (month < 1 || month > 12) {
        std::cout << "Invalid month.\n";
        return;
    }
    printMonthCalendar(year, month);
}

Todo* findTaskById(int id) {
    for (auto& task : todos) {
        if (task.id == id) {
            return &task;
        }
    }
    return nullptr;
}

void markCompleted() {
    int id;
    std::cout << "Task ID to mark complete: ";
    std::cin >> id;
    Todo* task = findTaskById(id);
    if (task == nullptr) {
        std::cout << "Task not found.\n";
        return;
    }
    task->completed = true;
    std::cout << "Task marked complete.\n";
}

void removeTask() {
    int id;
    std::cout << "Task ID to remove: ";
    std::cin >> id;
    auto it = std::remove_if(todos.begin(), todos.end(), [id](const Todo& task) {
        return task.id == id;
    });
    if (it == todos.end()) {
        std::cout << "Task not found.\n";
        return;
    }
    todos.erase(it, todos.end());
    std::cout << "Task removed.\n";
}
